{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .why-us-{{ section.id }} {
    --wu-radius: 2rem;
    --wu-border: rgba(255, 255, 255, 0.1);
    --wu-card-bg: rgba(var(--color-background), 0.22);
    --wu-shadow: 0 2.4rem 5rem rgba(var(--color-shadow), 0.12);
    --wu-panel: rgba(var(--color-background), 0.24);
    --wu-accent-cool: 168, 196, 255;
    --wu-accent-soft: 214, 224, 248;
    --wu-accent-muted: 172, 188, 216;
  }

  .why-us-{{ section.id }} .why-us__shell {
    position: relative;
    border-radius: calc(var(--wu-radius) + 1rem);
    padding: clamp(1.4rem, 2vw, 2.1rem);
    border: 0.1rem solid rgba(255, 255, 255, 0.15);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)),
      rgba(var(--color-background), 0.18);
    box-shadow:
      inset 0 0 0 0.1rem rgba(255, 255, 255, 0.04),
      0 1.8rem 4.2rem rgba(var(--color-shadow), 0.08);
    backdrop-filter: blur(18px) saturate(120%);
    -webkit-backdrop-filter: blur(18px) saturate(120%);
    overflow: hidden;
    isolation: isolate;
  }

  .why-us-{{ section.id }} .why-us__shell::before,
  .why-us-{{ section.id }} .why-us__shell::after {
    content: '';
    position: absolute;
    inset: auto;
    pointer-events: none;
    z-index: 0;
  }

  .why-us-{{ section.id }} .why-us__shell::before {
    top: -5rem;
    left: -4rem;
    width: 24rem;
    height: 24rem;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(var(--wu-accent-soft), 0.12) 0%, rgba(var(--wu-accent-soft), 0.04) 36%, transparent 70%);
    filter: blur(10px);
    opacity: 0.7;
  }

  .why-us-{{ section.id }} .why-us__shell::after {
    right: -8rem;
    bottom: -9rem;
    width: 30rem;
    height: 30rem;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(var(--wu-accent-cool), 0.07) 0%, rgba(var(--wu-accent-cool), 0.025) 34%, transparent 72%);
    filter: blur(16px);
    opacity: 0.55;
  }

  .why-us-{{ section.id }} .why-us__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.8rem;
    margin-bottom: 1.8rem;
    max-width: 72rem;
    position: relative;
    z-index: 1;
  }

  .why-us-{{ section.id }} .why-us__eyebrow {
    margin: 0;
    font-size: 1.1rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.56);
  }

  .why-us-{{ section.id }} .why-us__title {
    margin: 0;
    font-size: clamp(2.2rem, 3.2vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .why-us-{{ section.id }} .why-us__subtitle {
    margin: 0;
    color: rgba(var(--color-foreground), 0.68);
    font-size: 1.5rem;
    line-height: 1.45;
  }

  .why-us-{{ section.id }} .why-us__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-rows: minmax(5.4rem, auto);
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .why-us-{{ section.id }} .why-us__card {
    position: relative;
    grid-column: span 3;
    min-height: 8.6rem;
    padding: 1rem 1.1rem;
    display: grid;
    grid-template-columns: 3.4rem minmax(0, 1fr);
    grid-template-rows: auto auto;
    column-gap: 0.9rem;
    row-gap: 0.15rem;
    align-content: center;
    border-radius: var(--wu-radius);
    border: 0.1rem solid var(--wu-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01)),
      radial-gradient(circle at 14% 12%, rgba(var(--wu-accent-soft), 0.12), transparent 38%),
      var(--wu-card-bg);
    box-shadow:
      var(--wu-shadow),
      inset 0 0 0 0.1rem rgba(255, 255, 255, 0.025),
      inset 0 1.2rem 2rem rgba(255, 255, 255, 0.01);
    backdrop-filter: blur(22px) saturate(135%);
    -webkit-backdrop-filter: blur(22px) saturate(135%);
    overflow: hidden;
    isolation: isolate;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 320ms ease, border-color 320ms ease;
  }

  .why-us-{{ section.id }} .why-us__card > * {
    position: relative;
    z-index: 2;
  }

  .why-us-{{ section.id }} .why-us__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 12% 10%, rgba(var(--wu-accent-soft), 0.09), transparent 40%),
      radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.05), transparent 46%),
      linear-gradient(130deg, rgba(255, 255, 255, 0.05), transparent 42%);
    pointer-events: none;
    opacity: 0.65;
  }

  .why-us-{{ section.id }} .why-us__card::after {
    content: '';
    position: absolute;
    inset: -20% -10%;
    background:
      conic-gradient(from 180deg at 50% 50%, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
    filter: blur(24px);
    opacity: 0.28;
    transform: translate3d(0, 0, 0) rotate(0deg);
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease;
    pointer-events: none;
    z-index: 1;
  }

  .why-us-{{ section.id }} .why-us__card:hover {
    transform: translateY(-0.5rem);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow:
      0 2.8rem 5.8rem rgba(var(--color-shadow), 0.16),
      inset 0 0 0 0.1rem rgba(255, 255, 255, 0.03),
      inset 0 1.2rem 2rem rgba(255, 255, 255, 0.015);
  }

  .why-us-{{ section.id }} .why-us__card:hover::after {
    opacity: 0.45;
    transform: translate3d(1rem, -0.8rem, 0) rotate(8deg);
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(1) {
    grid-column: span 6;
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(2) {
    grid-column: span 6;
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(3) {
    grid-column: span 4;
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(4) {
    grid-column: span 8;
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(4n + 1) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)),
      radial-gradient(circle at 14% 12%, rgba(var(--wu-accent-cool), 0.12), transparent 38%),
      rgba(var(--color-background), 0.22);
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(4n + 2) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)),
      radial-gradient(circle at 84% 16%, rgba(var(--wu-accent-muted), 0.1), transparent 42%),
      rgba(var(--color-background), 0.22);
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(4n + 3) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)),
      radial-gradient(circle at 12% 84%, rgba(var(--wu-accent-cool), 0.07), transparent 40%),
      rgba(var(--color-background), 0.22);
  }

  .why-us-{{ section.id }} .why-us__card:nth-child(4n) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)),
      radial-gradient(circle at 88% 84%, rgba(var(--wu-accent-soft), 0.08), transparent 42%),
      rgba(var(--color-background), 0.22);
  }

  .why-us-{{ section.id }} .why-us__icon {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 1rem;
    display: grid;
    place-items: center;
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1;
    color: rgba(var(--color-foreground), 0.85);
    border: 0.1rem solid rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(var(--color-background), 0.34);
    box-shadow:
      inset 0 0 0 0.1rem rgba(255, 255, 255, 0.02),
      0 0.8rem 2rem rgba(var(--color-shadow), 0.08);
    backdrop-filter: blur(12px) saturate(130%);
    -webkit-backdrop-filter: blur(12px) saturate(130%);
    position: relative;
    overflow: hidden;
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: center;
  }

  .why-us-{{ section.id }} .why-us__icon::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 28% 20%, rgba(var(--wu-accent-soft), 0.1), transparent 42%),
      linear-gradient(140deg, rgba(255, 255, 255, 0.05), transparent 60%);
    opacity: 0.9;
    pointer-events: none;
  }

  .why-us-{{ section.id }} .why-us__card-title {
    margin: 0;
    font-size: clamp(1.75rem, 1.2vw, 2rem);
    line-height: 1.02;
    letter-spacing: -0.024em;
    max-width: none;
    grid-column: 2;
    grid-row: 1;
    align-self: end;
  }

  .why-us-{{ section.id }} .why-us__card-text {
    margin: 0;
    font-size: 1.28rem;
    line-height: 1.28;
    color: rgba(var(--color-foreground), 0.72);
    max-width: none;
    grid-column: 2;
    grid-row: 2;
    align-self: start;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .why-us-{{ section.id }} .why-us__index {
    position: absolute;
    top: 0.95rem;
    right: 0.95rem;
    font-size: 1rem;
    letter-spacing: 0.14em;
    color: rgba(var(--color-foreground), 0.42);
    padding: 0.28rem 0.42rem;
    border-radius: 999px;
    border: 0.1rem solid rgba(255, 255, 255, 0.12);
    background: rgba(var(--color-background), 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .why-us-{{ section.id }} .why-us__card:nth-child(odd) {
      animation: why-us-float-{{ section.id }} 8s ease-in-out infinite;
    }

    .why-us-{{ section.id }} .why-us__card:nth-child(even) {
      animation: why-us-float-{{ section.id }} 10s ease-in-out infinite reverse;
    }
  }

  @keyframes why-us-float-{{ section.id }} {
    0% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -0.35rem, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  @media screen and (max-width: 989px) {
    .why-us-{{ section.id }} .why-us__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: auto;
    }

    .why-us-{{ section.id }} .why-us__card,
    .why-us-{{ section.id }} .why-us__card:nth-child(1),
    .why-us-{{ section.id }} .why-us__card:nth-child(2),
    .why-us-{{ section.id }} .why-us__card:nth-child(3),
    .why-us-{{ section.id }} .why-us__card:nth-child(4) {
      grid-column: span 1;
      min-height: 8.4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .why-us-{{ section.id }} .why-us__shell {
      border-radius: 1.8rem;
      padding: 1rem;
    }

    .why-us-{{ section.id }} .why-us__head {
      gap: 0.6rem;
      margin-bottom: 1rem;
    }

    .why-us-{{ section.id }} .why-us__subtitle {
      font-size: 1.35rem;
    }

    .why-us-{{ section.id }} .why-us__grid {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .why-us-{{ section.id }} .why-us__card {
      min-height: 0;
      padding: 0.95rem 1rem;
      border-radius: 1.5rem;
      grid-template-columns: 3rem minmax(0, 1fr);
      column-gap: 0.75rem;
    }

    .why-us-{{ section.id }} .why-us__icon {
      width: 3rem;
      height: 3rem;
      border-radius: 0.95rem;
      margin: 0;
    }

    .why-us-{{ section.id }} .why-us__card-title {
      font-size: 1.55rem;
    }

    .why-us-{{ section.id }} .why-us__card-text {
      font-size: 1.2rem;
    }

    .why-us-{{ section.id }} .why-us__index {
      top: 0.9rem;
      right: 0.9rem;
      font-size: 0.95rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign locale_code = localization.language.iso_code | default: request.locale.iso_code | downcase
  assign is_spanish = false
  if locale_code contains 'es'
    assign is_spanish = true
  endif

  if is_spanish
    assign eyebrow_text = 'Por que Kor'
    assign title_text = 'Menos ruido. Mas criterio.'
    assign subtitle_text = 'Kor crea productos con una estetica limpia, materiales premium y una experiencia pensada para quienes valoran el detalle.'
  else
    assign eyebrow_text = section.settings.eyebrow
    assign title_text = section.settings.title
    assign subtitle_text = section.settings.subtitle
  endif

  assign translated_eyebrow = 'sections.why_us.eyebrow' | t
  assign translated_title = 'sections.why_us.title' | t
  assign translated_subtitle = 'sections.why_us.subtitle' | t

  unless translated_eyebrow contains 'translation missing'
    assign eyebrow_text = translated_eyebrow
  endunless

  unless translated_title contains 'translation missing'
    assign title_text = translated_title
  endunless

  unless translated_subtitle contains 'translation missing'
    assign subtitle_text = translated_subtitle
  endunless
-%}

<section class="why-us why-us-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="why-us__shell">
      <div class="why-us__head">
        {%- if eyebrow_text != blank -%}
          <p class="why-us__eyebrow">{{ eyebrow_text | escape }}</p>
        {%- endif -%}
        {%- if title_text != blank -%}
          <h2 class="why-us__title inline-richtext {{ section.settings.heading_size }}">{{ title_text }}</h2>
        {%- endif -%}
        {%- if subtitle_text != blank -%}
          <p class="why-us__subtitle">{{ subtitle_text }}</p>
        {%- endif -%}
      </div>

      <div class="why-us__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign card_title = block.settings.title | default: ''
            assign card_text = block.settings.text | default: ''

            if is_spanish and forloop.index <= 4
              case forloop.index
                when 1
                  assign card_title = 'Diseno con intencion'
                  assign card_text = 'Cada pieza existe por una razon: forma, funcion y detalle en equilibrio.'
                when 2
                  assign card_title = 'Materiales premium'
                  assign card_text = 'Acabados y texturas que se perciben desde el primer contacto.'
                when 3
                  assign card_title = 'Detalles precisos'
                  assign card_text = 'Nada sobra. Nada distrae. Cada elemento esta cuidado para durar.'
                when 4
                  assign card_title = 'Experiencia Kor'
                  assign card_text = 'Compra, presentacion y uso con una sensacion premium de principio a fin.'
              endcase
            endif

            assign card_title_key = 'sections.why_us.items.item_' | append: forloop.index | append: '.title'
            assign card_text_key = 'sections.why_us.items.item_' | append: forloop.index | append: '.text'
            assign translated_card_title = card_title_key | t
            assign translated_card_text = card_text_key | t

            unless translated_card_title contains 'translation missing'
              assign card_title = translated_card_title
            endunless

            unless translated_card_text contains 'translation missing'
              assign card_text = translated_card_text
            endunless
          -%}
          <article class="why-us__card" role="listitem" {{ block.shopify_attributes }}>
            <span class="why-us__index">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            {%- if block.settings.icon_text != blank -%}
              <div class="why-us__icon" aria-hidden="true">{{ block.settings.icon_text | escape }}</div>
            {%- endif -%}
            {%- if card_title != blank -%}
              <h3 class="why-us__card-title">{{ card_title | escape }}</h3>
            {%- endif -%}
            {%- if card_text != blank -%}
              <p class="why-us__card-text">{{ card_text }}</p>
            {%- endif -%}
          </article>
        {%- else -%}
          <article class="why-us__card" role="listitem">
            <span class="why-us__index">01</span>
            <div class="why-us__icon" aria-hidden="true">A</div>
            <h3 class="why-us__card-title">
              {%- if is_spanish -%}Diseno con intencion{%- else -%}Design with intent{%- endif -%}
            </h3>
            <p class="why-us__card-text">
              {%- if is_spanish -%}
                Cada pieza existe por una razon: forma, funcion y detalle en equilibrio.
              {%- else -%}
                Every piece exists for a reason: form, function, and detail in balance.
              {%- endif -%}
            </p>
          </article>
          <article class="why-us__card" role="listitem">
            <span class="why-us__index">02</span>
            <div class="why-us__icon" aria-hidden="true">B</div>
            <h3 class="why-us__card-title">
              {%- if is_spanish -%}Materiales premium{%- else -%}Premium materials{%- endif -%}
            </h3>
            <p class="why-us__card-text">
              {%- if is_spanish -%}
                Acabados y texturas que se perciben desde el primer contacto.
              {%- else -%}
                Finishes and textures you can feel from the first touch.
              {%- endif -%}
            </p>
          </article>
          <article class="why-us__card" role="listitem">
            <span class="why-us__index">03</span>
            <div class="why-us__icon" aria-hidden="true">C</div>
            <h3 class="why-us__card-title">
              {%- if is_spanish -%}Detalles precisos{%- else -%}Precise details{%- endif -%}
            </h3>
            <p class="why-us__card-text">
              {%- if is_spanish -%}
                Nada sobra. Nada distrae. Cada elemento esta cuidado para durar.
              {%- else -%}
                Nothing extra. Nothing distracting. Every element is crafted to last.
              {%- endif -%}
            </p>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why us",
  "tag": "section",
  "class": "section section-why-us",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Why Kor"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Less noise. More criteria."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Kor creates products with clean aesthetics, premium materials, and an experience built for people who value detail."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Differentiator",
      "settings": [
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon text",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Design with intent"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every piece exists for a reason: form, function, and detail in balance."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why us",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon_text": "01",
            "title": "Design with intent",
            "text": "Every piece exists for a reason: form, function, and detail in balance."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon_text": "02",
            "title": "Premium materials",
            "text": "Finishes and textures you can feel from the first touch."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon_text": "03",
            "title": "Precise details",
            "text": "Nothing extra. Nothing distracting. Every element is crafted to last."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon_text": "04",
            "title": "Kor experience",
            "text": "Shopping, presentation, and use with a premium feel from start to finish."
          }
        }
      ]
    }
  ]
}
{% endschema %}
