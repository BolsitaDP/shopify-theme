<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}


<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    top: 0;
    z-index: 30;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-header .header-wrapper {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
  }

  .section-header .header-wrapper--border-bottom {
    border-bottom: 0;
  }

  @media screen and (min-width: 990px) {
    .section-header,
    .section-header .header-wrapper,
    .section-header .header-wrapper.gradient,
    .shopify-section-group-header-group,
    .shopify-section-group-header-group .shopify-section {
      background: transparent !important;
      box-shadow: none !important;
      border-color: transparent !important;
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
    }
  }

  .section-header .header {
    position: relative;
    margin: 0.55rem auto;
    border-radius: 2rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.06);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.015)),
      rgba(var(--color-background), 0.46);
    -webkit-backdrop-filter: blur(18px) saturate(1.15);
    backdrop-filter: blur(18px) saturate(1.15);
    box-shadow:
      0 1rem 2.4rem rgba(var(--color-shadow), 0.1),
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.08);
  }

  .section-header .header::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(circle at 14% -25%, rgba(255, 255, 255, 0.12), transparent 55%);
    opacity: 0.45;
  }

  .section-header .header > * {
    position: relative;
    z-index: 1;
  }

  .section-header .header__heading-link {
    border-radius: 1.4rem;
    padding: 0.3rem 0.6rem;
    transition: background-color 180ms ease, box-shadow 180ms ease;
  }

  .section-header .header__heading-link:hover {
    background: rgba(var(--color-foreground), 0.025);
    box-shadow: inset 0 0.1rem 0 rgba(255, 255, 255, 0.08);
  }

  .section-header .header__inline-menu .list-menu--inline {
    gap: 0.4rem;
  }

  .section-header .header__menu-item {
    border-radius: 999px;
    padding: 0.65rem 1.1rem;
    transition:
      background-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .section-header .header__menu-item:hover,
  .section-header details[open] > .header__menu-item {
    background: rgba(var(--color-foreground), 0.035);
    box-shadow:
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.1),
      0 0.5rem 1.1rem rgba(var(--color-shadow), 0.05);
    text-decoration: none;
  }

  .section-header .header__menu-item:hover span,
  .section-header .header__active-menu-item,
  .section-header details[open] > .header__menu-item {
    text-decoration: none;
  }

  .section-header .header__icons {
    gap: 0.4rem;
    padding-right: 0;
    align-items: center;
  }

  .section-header .header__icon {
    border-radius: 999px;
    border: 0.1rem solid rgba(var(--color-foreground), 0.05);
    background: rgba(var(--color-foreground), 0.015);
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .section-header .header__icon,
  .section-header .header__icon--cart .icon {
    width: 3.6rem;
    height: 3.6rem;
  }

  .section-header .header__icon .svg-wrapper {
    width: 3.6rem;
    height: 3.6rem;
  }

  .section-header .header__icon:hover,
  .section-header details[open] > .header__icon--menu {
    background: rgba(var(--color-foreground), 0.04);
    border-color: rgba(var(--color-foreground), 0.08);
    box-shadow:
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.08),
      0 0.6rem 1.4rem rgba(var(--color-shadow), 0.06);
  }

  .section-header .header__icon--cart {
    margin-right: 0;
  }

  .section-header .mobile-island-nav {
    display: none;
  }

  .section-header .header__mobile-lang {
    display: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) {
    align-items: center;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .desktop-localization-wrapper {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-right: 0.2rem;
  }

  .section-header .header-localization.header-localization--desktop .localization-form__select > span {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    max-width: 4.5ch;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .localization-form {
    padding: 0;
    margin: 0;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure {
    position: relative;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure .localization-form__select {
    margin: 0;
    min-width: 0;
    width: auto;
    height: 3.1rem;
    min-height: 3.1rem;
    padding: 0 3.2rem 0 1.2rem;
    border-radius: 999px;
    border: 0.1rem solid rgba(var(--color-foreground), 0.09);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02)),
      rgba(var(--color-foreground), 0.025);
    color: rgba(var(--color-foreground), 0.9);
    letter-spacing: 0.02rem;
    text-decoration: none;
    -webkit-backdrop-filter: blur(12px) saturate(1.05);
    backdrop-filter: blur(12px) saturate(1.05);
    box-shadow:
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.16),
      0 0.6rem 1.4rem rgba(var(--color-shadow), 0.05);
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .localization-form__select:before,
  .section-header .header-localization:not(.menu-drawer__localization) .localization-form__select:after {
    content: none;
    box-shadow: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure .localization-form__select:hover,
  .section-header .header-localization:not(.menu-drawer__localization) .disclosure .localization-form__select:focus-visible {
    text-decoration: none;
    border-color: rgba(var(--color-foreground), 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.03)),
      rgba(var(--color-foreground), 0.05);
    box-shadow:
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.22),
      0 0.9rem 2rem rgba(var(--color-shadow), 0.07);
    outline: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .localization-form__select > span {
    max-width: 23ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .localization-form__select .icon-caret {
    right: 1.1rem;
    width: 1rem;
    height: 0.7rem;
    opacity: 0.8;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__button[aria-expanded='true'] {
    border-color: rgba(var(--color-foreground), 0.15);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.03)),
      rgba(var(--color-foreground), 0.055);
    box-shadow:
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.2),
      0 1rem 2rem rgba(var(--color-shadow), 0.08);
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__button[aria-expanded='true'] .icon-caret {
    opacity: 1;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__list-wrapper {
    top: calc(100% + 0.8rem);
    right: 0;
    bottom: auto;
    transform: none;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.6rem;
    background: rgba(var(--color-background), 0.86);
    -webkit-backdrop-filter: blur(18px) saturate(1.08);
    backdrop-filter: blur(18px) saturate(1.08);
    box-shadow: 0 1.4rem 3rem rgba(var(--color-shadow), 0.12);
    overflow: hidden;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__list {
    padding: 0.8rem;
    max-width: min(34rem, 80vw);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__list::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-selector__list {
    padding-top: 0.2rem;
    padding-bottom: 0.8rem;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .popular-countries {
    border-bottom-color: rgba(var(--color-foreground), 0.08);
    margin: 0 0.2rem;
    padding: 0.4rem 0 0.8rem;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__link {
    border-radius: 1.1rem;
    padding: 1rem 1.1rem;
    color: rgba(var(--color-foreground), 0.82);
    transition: background-color 160ms ease, color 160ms ease;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__link:hover,
  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__link:focus-visible {
    text-decoration: none;
    color: rgb(var(--color-foreground));
    background: rgba(var(--color-foreground), 0.045);
    outline: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .disclosure__link[aria-current='true'] {
    background: rgba(var(--color-foreground), 0.06);
    box-shadow: inset 0 0.1rem 0 rgba(255, 255, 255, 0.16);
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter {
    padding: 1rem 1rem 0.6rem;
    background: rgba(var(--color-background), 0.9);
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter .field {
    border-radius: 999px;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    background: rgba(var(--color-foreground), 0.025);
    box-shadow: inset 0 0.1rem 0 rgba(255, 255, 255, 0.14);
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter .field:before,
  .section-header .header-localization:not(.menu-drawer__localization) .country-filter .field:after {
    content: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter__input {
    min-height: 4rem;
    height: 4rem;
    padding-top: 0;
    padding-bottom: 0;
    line-height: 4rem;
    background: transparent;
    box-shadow: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter .field__label {
    display: none;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter__search-icon,
  .section-header .header-localization:not(.menu-drawer__localization) .country-filter__reset-button {
    background: transparent;
    box-shadow: none;
    border: 0;
  }

  .section-header .header-localization:not(.menu-drawer__localization) .country-filter__reset-button:not(:focus-visible)::after,
  .section-header .header-localization:not(.menu-drawer__localization) .country-filter__reset-button:not(:focus)::after {
    content: none;
  }

  .section-header .header__search-inline {
    position: relative;
    z-index: 4;
  }

  .section-header .header__search-inline details {
    position: relative;
    width: 3.6rem;
    min-width: 3.6rem;
    height: 3.6rem;
    transition: width 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .section-header .header__search-inline summary {
    list-style: none;
  }

  .section-header .header__search-inline summary::-webkit-details-marker {
    display: none;
  }

  .section-header .header__search-toggle {
    position: relative;
    z-index: 2;
    transition:
      background-color 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .section-header .header__search-toggle .svg-wrapper {
    transition:
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .section-header .header__search-shell {
    position: absolute;
    top: 50%;
    right: 0;
    width: min(42rem, calc(100vw - 3.2rem));
    transform: translateY(-50%) scaleX(0.86) translateX(1.2rem);
    transform-origin: right center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease,
      visibility 0s linear 260ms;
  }

  .section-header .header__search-form-wrap {
    position: relative;
    display: block;
  }

  .section-header .header__search-form {
    margin: 0;
  }

  .section-header .header__search-form .field {
    position: relative;
    border-radius: 999px;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.02)),
      rgba(var(--color-background), 0.78);
    -webkit-backdrop-filter: blur(16px) saturate(1.1);
    backdrop-filter: blur(16px) saturate(1.1);
    box-shadow:
      0 1rem 2.2rem rgba(var(--color-shadow), 0.1),
      inset 0 0.1rem 0 rgba(255, 255, 255, 0.2);
    overflow: hidden;
    transition:
      box-shadow 220ms ease,
      border-color 220ms ease,
      background-color 220ms ease;
  }

  .section-header .header__search-form .field::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(circle at 12% -35%, rgba(255, 255, 255, 0.26), transparent 56%);
  }

  .section-header .header__search-form .field__input {
    min-height: 3.6rem;
    height: 3.6rem;
    border: 0;
    background: transparent;
    box-shadow: none;
    padding-top: 0;
    padding-bottom: 0;
    padding-left: 5rem;
    padding-right: 9.2rem;
    line-height: 3.6rem;
    color: rgb(var(--color-foreground));
    opacity: 0;
    transition:
      opacity 160ms ease 40ms,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    transform: translateX(0.6rem);
  }

  .section-header .header__search-form .field__input::placeholder {
    color: rgba(var(--color-foreground), 0.6);
    opacity: 1;
  }

  .section-header .header__search-form .field__label {
    display: none;
  }

  .section-header .header__search-form .search__button,
  .section-header .header__search-form .reset__button {
    background: transparent;
    box-shadow: none;
    border: 0;
  }

  .section-header .header__search-form .search__button {
    right: 0.3rem;
    top: 0.3rem;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
  }

  .section-header .header__search-form .reset__button {
    right: 3.5rem;
    top: 0.3rem;
    width: 2.6rem;
    height: 3rem;
    opacity: 0.75;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .section-header .header__search-form .reset__button:not(:focus-visible)::after,
  .section-header .header__search-form .reset__button:not(:focus)::after {
    content: none;
  }

  .section-header .header__search-form .reset__button:hover {
    opacity: 1;
    transform: scale(1.06);
    background: transparent;
  }

  .section-header .header__search-form .reset__button:focus,
  .section-header .header__search-form .reset__button:focus-visible {
    background: transparent;
    box-shadow: none;
    opacity: 1;
  }

  .section-header .header__search-form .reset__button > .svg-wrapper {
    width: 1.8rem;
    height: 1.8rem;
  }

  .section-header .header__search-form .reset__button .icon,
  .section-header .header__search-form .reset__button .icon.icon-close {
    width: 1.5rem;
    height: 1.5rem;
    stroke-width: 0.16rem;
  }

  .section-header .header__search-inline details[open] {
    width: min(42rem, calc(100vw - 3.2rem));
  }

  .section-header .header__search-inline details[open] .header__search-shell {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(-50%) scaleX(1) translateX(0);
    transition-delay: 0s, 0s, 0s;
  }

  .section-header .header__search-inline details[open] .header__search-form .field__input {
    opacity: 1;
    transform: translateX(0);
  }

  .section-header .header__search-inline details[open] .header__search-toggle {
    background: transparent;
    border-color: transparent;
    box-shadow: none;
  }

  .section-header .header__search-inline details[open] .header__search-toggle .svg-wrapper {
    opacity: 0;
    transform: scale(0.75);
  }

  .section-header .header__search-inline .predictive-search--header {
    margin-top: 0.6rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.4rem;
    background: rgba(var(--color-background), 0.88);
    -webkit-backdrop-filter: blur(16px) saturate(1.08);
    backdrop-filter: blur(16px) saturate(1.08);
    box-shadow: 0 1.4rem 3rem rgba(var(--color-shadow), 0.12);
    overflow: hidden;
  }

  .section-header .header__search-inline .predictive-search__results-groups-wrapper {
    border-bottom-color: rgba(var(--color-foreground), 0.06);
  }

  .section-header .header__search-inline .predictive-search__list-item[aria-selected='true'] > *,
  .section-header .header__search-inline .predictive-search__list-item:hover > *,
  .section-header .header__search-inline .predictive-search__item[aria-selected='true'],
  .section-header .header__search-inline .predictive-search__item:hover {
    border-radius: 1rem;
    background: rgba(var(--color-foreground), 0.045);
  }

  .section-header .header__submenu,
  .section-header .header__submenu.global-settings-popup,
  .section-header .mega-menu__content {
    border-radius: 1.6rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    background: rgba(var(--color-background), 0.82);
    -webkit-backdrop-filter: blur(18px) saturate(1.1);
    backdrop-filter: blur(18px) saturate(1.1);
    box-shadow: 0 1.4rem 3.2rem rgba(var(--color-shadow), 0.14);
  }

  @media screen and (max-width: 989px) {
    .section-header .header {
      margin: 0.4rem 0.5rem;
      border-radius: 1.6rem;
    }

    .section-header .header__search-shell,
    .section-header .header__search-inline details[open] {
      width: min(34rem, calc(100vw - 2.4rem));
    }
  }

  @media screen and (max-width: 749px) {
    .section-header {
      top: 0;
      z-index: 2147483000 !important;
    }

    .section-header.shopify-section-group-header-group,
    .section-header.shopify-section-header-sticky,
    .section-header.shopify-section-header-hidden,
    .section-header.animate {
      z-index: 2147483000 !important;
    }

    .section-header .header-wrapper {
      background: transparent !important;
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
    }

    .section-header .header {
      margin: 0;
      border-radius: 0;
      border-left: 0;
      border-right: 0;
      border-top: 0;
      background: rgb(var(--color-background)) !important;
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
      border-bottom: 0.1rem solid rgba(255, 255, 255, 0.08);
      box-shadow:
        0 0.6rem 1.4rem rgba(var(--color-shadow), 0.08),
        inset 0 0.1rem 0 rgba(255, 255, 255, 0.04);
    }

    .section-header .header::before {
      content: none;
    }

    .section-header .header-wrapper--border-bottom {
      border-bottom: 0;
    }

    .section-header header-drawer,
    .section-header .header__icon--menu,
    .section-header .header__icons {
      display: none !important;
    }

    .section-header .header {
      grid-template-areas: 'heading';
